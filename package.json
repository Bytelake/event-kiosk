{
  "name": "event-kiosk",
  "version": "0.0.2",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "dev:shell": "npm run dev --workspace=shell",
    "dev:desktop": "bash scripts/dev-desktop.sh",
    "build": "npm run build --workspace=web",
    "build:shell": "npm run build --workspace=shell",
    "start": "npm run start --workspace=web",
    "db:generate": "npm run db:generate --workspace=web",
    "db:migrate": "npm run db:migrate --workspace=web",
    "db:push": "npm run db:push --workspace=web",
    "package:debian": "bash scripts/build-debian-package.sh",
    "package:debian:prerelease": "bash scripts/build-debian-package.sh --pre-release",
    "package:alpine": "bash scripts/build-alpine-package.sh",
    "package:alpine:prerelease": "bash scripts/build-alpine-package.sh --pre-release",
    "package:pi": "bash scripts/build-pi-package.sh"
  }
}
