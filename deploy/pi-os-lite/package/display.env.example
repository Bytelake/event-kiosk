# Display settings for the kiosk hardware (not the web app).
# Copy to /opt/kiosk/display.env and edit, then restart the display service.
#
# Rotation for vertically mounted monitors.
# Values: normal | left | right | inverted
#
# Raspberry Pi (Wayland/cage): applied with wlr-randr when kiosk-display starts.
# Generic Linux (X11): applied automatically when kiosk-shell starts.

KIOSK_DISPLAY_ROTATION=normal
