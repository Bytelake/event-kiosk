DATABASE_URL="file:./prisma/dev.db"
# Pi production (set automatically by install.sh):
# DATABASE_URL="file:/var/lib/kiosk/kiosk.db"
# UPLOADS_DIR="/var/lib/kiosk/uploads"
ADMIN_PASSWORD="changeme"
SESSION_SECRET="change-this-to-a-long-random-string"
# Leave false when accessing admin over HTTP (e.g. http://192.168.x.x:3000 on a Pi)
COOKIE_SECURE="false"
# Set true for local desktop dev (visible cursor, no idle redirect)
KIOSK_DESKTOP_MODE="false"
BREEZE_SUBDOMAIN=""
BREEZE_API_KEY=""
