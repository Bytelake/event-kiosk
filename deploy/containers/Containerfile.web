# Build stage — Next.js standalone + Prisma for linux-amd64
FROM node:20-bookworm-slim AS builder

WORKDIR /build
COPY package.json package-lock.json ./
COPY apps/web/package.json apps/web/
COPY apps/web/prisma apps/web/prisma
RUN npm ci --workspace=web --ignore-scripts

COPY apps/web apps/web
WORKDIR /build/apps/web
RUN cp .env.example .env
RUN npx prisma generate --schema=prisma/schema.prisma
RUN npm run build

# Runtime stage
FROM node:20-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /build/apps/web/.next/standalone ./
COPY --from=builder /build/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /build/apps/web/public ./apps/web/public
COPY --from=builder /build/apps/web/prisma ./prisma
COPY --from=builder /build/node_modules/.prisma ./node_modules/.prisma
COPY --from=builder /build/node_modules/@prisma ./node_modules/@prisma

ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

EXPOSE 3000
CMD ["node", "apps/web/server.js"]
