# Display settings for the kiosk hardware (not the web app).
# Production installs store this at /var/lib/kiosk/display.env
#
# Rotation for vertically mounted monitors.
# Values: normal | left | right | inverted
#
# Wayland/cage: applied with wlr-randr when kiosk-display starts.
# X11/session: applied automatically when kiosk-shell starts.

KIOSK_DISPLAY_ROTATION=normal
